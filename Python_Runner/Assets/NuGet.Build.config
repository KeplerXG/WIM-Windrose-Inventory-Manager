<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Isolated feed for scripted builds. Ignores machine or user NuGet.config layers. -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
